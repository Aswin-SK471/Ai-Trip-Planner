# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_NAME=aitripplanner
DB_PORT=3306

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production_min_32_chars

# ============================================
# GOOGLE PLACES API
# ============================================
# Get from: https://console.cloud.google.com/credentials
# 1. Create a new project
# 2. Enable: Places API + Maps JavaScript API
# 3. Create an API Key
# 4. Restrict by HTTP referrer: http://localhost:3000/*
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_api_key_here

# ============================================
# AMADEUS FLIGHT API
# ============================================
# Get from: https://developers.amadeus.com
# 1. Sign up for an account
# 2. Create a new application
# 3. Copy Client ID and Client Secret
AMADEUS_API_KEY=your_amadeus_client_id
AMADEUS_API_SECRET=your_amadeus_client_secret

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_MOCK_FLIGHTS=true
ENABLE_GOOGLE_PLACES=true
